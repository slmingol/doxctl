#!/bin/bash
# Wrapper to run doxctl in container with macOS VPN DNS auto-detection

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "=== doxctl Container Launcher (macOS) ==="
echo

# Check if VPN is connected by looking for DNS servers
VPN_DNS=$(scutil --dns 2>/dev/null | grep "nameserver\[" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -2)

if [ -z "$VPN_DNS" ]; then
    echo -e "${RED}ERROR: No DNS servers detected!${NC}"
    echo "Please connect to your VPN first."
    exit 1
fi

# Count DNS servers
DNS_COUNT=$(echo "$VPN_DNS" | wc -l | tr -d ' ')

if [ "$DNS_COUNT" -lt 1 ]; then
    echo -e "${RED}ERROR: No VPN DNS servers found${NC}"
    exit 1
fi

echo -e "${GREEN}✓ VPN Connected${NC}"

# Extract DNS configuration
SEARCH_DOMAIN=$(scutil --dns | grep "search domain\[0\]" | head -1 | sed 's/.*: //')
DOMAIN=$(scutil --dns | grep "domain " | head -1 | awk '{print $3}')

echo "  DNS Servers: $(echo $VPN_DNS | tr '\n' ', ' | sed 's/,$//')"
echo "  Search Domain: ${SEARCH_DOMAIN:-none}"
echo "  Domain: ${DOMAIN:-none}"
echo

# Create resolv.conf for container
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RESOLV_FILE="$SCRIPT_DIR/resolv.conf.vpn"

cat > "$RESOLV_FILE" <<EOF
domain ${DOMAIN:-local}
search ${SEARCH_DOMAIN:-local}
$(echo "$VPN_DNS" | while read dns; do echo "nameserver $dns"; done)
EOF

echo -e "${GREEN}✓ Created DNS config${NC}"

# Build DNS flags for podman
DNS_FLAGS=""
for dns in $VPN_DNS; do
    DNS_FLAGS="$DNS_FLAGS --dns $dns"
done
[ -n "$SEARCH_DOMAIN" ] && DNS_FLAGS="$DNS_FLAGS --dns-search $SEARCH_DOMAIN"

# Check if config exists
if [ ! -f "$SCRIPT_DIR/doxctl.yaml" ]; then
    echo -e "${YELLOW}WARNING: doxctl.yaml not found in $SCRIPT_DIR${NC}"
    echo "Using container default config"
    CONFIG_MOUNT=""
else
    CONFIG_MOUNT="-v $SCRIPT_DIR/doxctl.yaml:/root/.doxctl.yaml"
fi

echo -e "${GREEN}✓ Launching container...${NC}"
echo

# Run container
exec podman run --rm \
    $DNS_FLAGS \
    -v "$RESOLV_FILE:/etc/resolv.conf:ro" \
    $CONFIG_MOUNT \
    doxctl:macos-vpn \
    "$@"
