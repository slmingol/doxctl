#!/bin/bash
# Wrapper to run doxctl in container with macOS VPN DNS auto-detection

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "=== doxctl Container Launcher (macOS) ==="
echo

# Check if VPN is connected by looking for DNS servers
VPN_DNS=$(scutil --dns 2>/dev/null | grep "nameserver\[" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -2)

if [ -z "$VPN_DNS" ]; then
    echo -e "${RED}ERROR: No DNS servers detected!${NC}"
    echo "Please connect to your VPN first."
    exit 1
fi

# Count DNS servers
DNS_COUNT=$(echo "$VPN_DNS" | wc -l | tr -d ' ')

if [ "$DNS_COUNT" -lt 1 ]; then
    echo -e "${RED}ERROR: No VPN DNS servers found${NC}"
    exit 1
fi

echo -e "${GREEN}✓ VPN Connected${NC}"

# Extract DNS configuration
SEARCH_DOMAIN=$(scutil --dns | grep "search domain\[0\]" | head -1 | sed 's/.*: //')

echo "  DNS Servers: $(echo $VPN_DNS | tr '\n' ', ' | sed 's/,$//')"
echo "  Search Domain: ${SEARCH_DOMAIN:-none}"
echo

# Create resolv.conf for container
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RESOLV_FILE="$SCRIPT_DIR/resolv.conf.vpn"

cat > "$RESOLV_FILE" <<EOF
domain ${SEARCH_DOMAIN:-local}
search ${SEARCH_DOMAIN:-local}
$(echo "$VPN_DNS" | while read dns; do echo "nameserver $dns"; done)
EOF

echo -e "${GREEN}✓ Created DNS config${NC}"

# Gather VPN diagnostic information for passing to container
# Get network interfaces
NET_IFS=$(scutil --nwi 2>/dev/null | grep 'Network interfaces:' | cut -d" " -f 3- || echo "")
IF_COUNT=$(echo "$NET_IFS" | wc -w | tr -d ' ')

# Check for TUN interfaces
TUN_IFS=$(echo "$NET_IFS" | tr ' ' '\n' | grep 'tun' || echo "")
HAS_TUN="false"
if [ -n "$TUN_IFS" ]; then
    HAS_TUN="true"
fi

# Get VPN interface (first utun found)
VPN_IF=$(scutil --nwi 2>/dev/null | grep 'Network interfaces:' | grep -o 'utun[0-9]' | head -1 || echo "NIL")

# Count VPN routes
if [ "$VPN_IF" != "NIL" ]; then
    VPN_ROUTE_COUNT=$(netstat -r -f inet 2>/dev/null | grep -c "$VPN_IF" || echo "0")
else
    VPN_ROUTE_COUNT="0"
fi

# Check VPN client connection status (Cisco AnyConnect)
VPN_CONNECTED="false"
if [ -x "/opt/cisco/anyconnect/bin/vpn" ]; then
    if /opt/cisco/anyconnect/bin/vpn state 2>/dev/null | grep -q 'state: Connected'; then
        VPN_CONNECTED="true"
    fi
fi

# Check if all interfaces are reachable
UNREACHABLE_COUNT=$(scutil --nwi 2>/dev/null | grep address -B1 -A1 | grep -E "flags|reach" | paste - - | column -t | grep -v Reachable | wc -l | tr -d ' ')
ALL_IFS_REACHABLE="false"
if [ "$UNREACHABLE_COUNT" = "0" ]; then
    ALL_IFS_REACHABLE="true"
fi

# Build DNS flags for podman
DNS_FLAGS=""
for dns in $VPN_DNS; do
    DNS_FLAGS="$DNS_FLAGS --dns $dns"
done
[ -n "$SEARCH_DOMAIN" ] && DNS_FLAGS="$DNS_FLAGS --dns-search $SEARCH_DOMAIN"

# Check if config exists
if [ ! -f "$SCRIPT_DIR/doxctl.yaml" ]; then
    echo -e "${YELLOW}WARNING: doxctl.yaml not found in $SCRIPT_DIR${NC}"
    echo "Using container default config"
    CONFIG_MOUNT=""
else
    CONFIG_MOUNT="-v $SCRIPT_DIR/doxctl.yaml:/root/.doxctl.yaml"
fi

echo -e "${GREEN}✓ Launching container...${NC}"
echo

# Run container with CAP_NET_RAW for ping functionality
exec podman run --rm -it \
    --cap-add=CAP_NET_RAW \
    $DNS_FLAGS \
    -v "$RESOLV_FILE:/etc/resolv.conf:ro" \
    $CONFIG_MOUNT \
    -e "HOST_VPN_NET_IFS=$NET_IFS" \
    -e "HOST_VPN_IF_COUNT=$IF_COUNT" \
    -e "HOST_VPN_TUN_IFS=$TUN_IFS" \
    -e "HOST_VPN_HAS_TUN=$HAS_TUN" \
    -e "HOST_VPN_INTERFACE=$VPN_IF" \
    -e "HOST_VPN_ROUTE_COUNT=$VPN_ROUTE_COUNT" \
    -e "HOST_VPN_CONNECTED=$VPN_CONNECTED" \
    -e "HOST_VPN_ALL_IFS_REACHABLE=$ALL_IFS_REACHABLE" \
    doxctl:latest \
    "$@"
